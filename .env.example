# Supabase auth + encrypted per-user credentials.
# Add all four to enable multi-user login mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_ENCRYPTION_KEY=

# Optional fallback values used only when Supabase auth mode is not enabled.
OPENAI_API_KEY=
OPENAI_TASK_MODEL=gpt-5.5
OPENAI_TRANSCRIPTION_LANGUAGE=en

CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=
CLICKUP_DEFAULT_ASSIGNEE_ID=

PORT=3000
